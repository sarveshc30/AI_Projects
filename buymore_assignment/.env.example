# Groq API keys. Two are required: the agent falls back to the second key when the
# first hits a rate limit, expires, or times out. Get them at https://console.groq.com
GROQ_API_KEY_1=your_primary_groq_api_key_here
GROQ_API_KEY_2=your_secondary_groq_api_key_here

# Optional - defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
